---
import { Image } from 'astro:assets';
import logoWhite from '../assets/brand/logo-white.png';
import { WHATSAPP_LINK, EMAIL, SITE_NAME, SITE_URL, CRM_LINK } from '../config';

const year = new Date().getFullYear();
const pagespeedUrl = `https://pagespeed.web.dev/analysis?url=${SITE_URL}`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <Image src={logoWhite} alt="WordPane" width={440} format="webp" />
        <p>Desenvolvimento de sites e sistemas sob medida, feitos para converter.</p>
        <p>Atendemos clientes em todo o Brasil.</p>
        <a class="footer-badge" id="pagespeed-badge" href={pagespeedUrl} target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
          Este site é nossa vitrine: teste nossa velocidade
        </a>
      </div>
      <nav class="footer-nav" aria-label="Rodapé">
        <div>
          <strong>Serviços</strong>
          <ul>
            <li><a href="/desenvolvimento-de-sites/">Desenvolvimento de Sites</a></li>
            <li><a href="/desenvolvimento-de-sistemas/">Desenvolvimento de Sistemas</a></li>
          </ul>
        </div>
        <div>
          <strong>Navegação</strong>
          <ul>
            <li><a href="/#processo">Processo</a></li>
            <li><a href="/#faq">Dúvidas</a></li>
            <li><a href={CRM_LINK} target="_blank" rel="noopener">Acesso ao CRM</a></li>
          </ul>
        </div>
        <div>
          <strong>Contato</strong>
          <ul>
            <li>
              <a href={WHATSAPP_LINK} target="_blank" rel="noopener">WhatsApp</a>
            </li>
            <li><a href={`mailto:${EMAIL}`}>{EMAIL}</a></li>
            <li><span>Seg. a sex., 9h às 18h</span></li>
            <li><span>Resposta em poucos minutos</span></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© {year} {SITE_NAME}. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<script>
  const pagespeedBadge = document.getElementById('pagespeed-badge');
  if (pagespeedBadge) {
    pagespeedBadge.setAttribute(
      'href',
      `https://pagespeed.web.dev/analysis?url=${window.location.origin}`
    );
  }
</script>
