---
import { WHATSAPP_LINK } from '../config';

const features = [
  {
    title: 'Renderização no servidor',
    desc: 'O site chega pronto ao navegador: HTML leve e completo, sem JavaScript desnecessário pesando no carregamento.',
    icon: '<path d="M4 14h6v6H4z" /><path d="M4 4h6v6H4z" /><path d="M14 4h6v6h-6z" /><path d="M14 14h6v6h-6z" />',
  },
  {
    title: 'Ilhas de interatividade',
    desc: 'Apenas as partes realmente interativas carregam código extra — e só quando o visitante precisa. O resto é velocidade pura.',
    icon: '<circle cx="12" cy="12" r="3" /><circle cx="5" cy="5" r="2" /><circle cx="19" cy="5" r="2" /><circle cx="5" cy="19" r="2" /><circle cx="19" cy="19" r="2" />',
  },
  {
    title: 'Imagens otimizadas',
    desc: 'Formatos modernos e dimensões sob medida para cada dispositivo, gerados automaticamente, sem trabalho manual.',
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" />',
  },
  {
    title: 'Navegação instantânea',
    desc: 'Pré-carregamento inteligente faz a próxima página abrir antes mesmo de o visitante terminar o clique.',
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />',
  },
  {
    title: 'Zero dependência de fornecedor',
    desc: 'Tecnologia aberta e auditável: seu site nunca fica refém de uma plataforma, licença ou mensalidade obrigatória.',
    icon: '<rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 9.9-1" />',
  },
  {
    title: 'Preparada para o futuro',
    desc: 'Compatível com as ferramentas mais modernas de design, conteúdo e IA. Seu investimento não envelhece.',
    icon: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" />',
  },
];
---

<section id="tecnologia" class="tech">
  <div class="container tech-grid">
    <div class="tech-intro" data-reveal>
      <span class="eyebrow">Tecnologia de ponta</span>
      <h2>A mesma tecnologia usada pelas <span class="gradient-text">maiores empresas do mundo</span></h2>
      <p>
        Nossos sites são construídos sobre uma das tecnologias web mais
        avançadas e premiadas do mercado — de código aberto, auditada por
        milhares de especialistas e escolhida por gigantes globais da
        tecnologia para seus próprios sites.
      </p>

      <div class="cwv">
        <p class="cwv-title">
          Sites com boas notas nas métricas oficiais do Google (Core Web Vitals)
        </p>
        <div class="cwv-row">
          <div class="cwv-label">
            <span>Nossa tecnologia</span>
            <strong>66%</strong>
          </div>
          <div class="cwv-bar"><i style="--w: 66%"></i></div>
        </div>
        <div class="cwv-row">
          <div class="cwv-label">
            <span>WordPress</span>
            <strong>48%</strong>
          </div>
          <div class="cwv-bar wp"><i style="--w: 48%"></i></div>
        </div>
        <p class="cwv-source">
          Fonte: HTTP Archive e Chrome UX Report — dados reais de milhões de
          sites em produção.
        </p>
      </div>

      <a class="btn btn-primary" href={WHATSAPP_LINK} target="_blank" rel="noopener">
        Quero essa tecnologia no meu site
      </a>
    </div>

    <div class="tech-features">
      {features.map((f) => (
        <div class="tech-feature" data-reveal>
          <span class="icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </span>
          <div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
