---
import { WHATSAPP_LINK } from '../config';
---

<section class="hero hero-full">
  <div class="container">
    <div class="hero-inner">
      <span class="eyebrow">Agência de desenvolvimento de sites e sistemas web</span>
      <h1>
        <span class="line">Sites e sistemas web sob medida</span> <span class="line gradient-text">para empresas de todos os tamanhos.</span>
      </h1>
      <p class="hero-sub">
        A WordPane projeta e desenvolve sites ultrarrápidos e sistemas web para
        pequenas, médias e grandes empresas — com tecnologia moderna, entrega
        ágil e acompanhamento transparente pelo nosso CRM.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={WHATSAPP_LINK} target="_blank" rel="noopener">
          Solicitar proposta gratuita
        </a>
        <a class="btn btn-outline" href="#servicos">Conhecer as soluções</a>
      </div>
      <p class="hero-note">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
        Resposta em poucos minutos · Proposta gratuita · Sem compromisso
      </p>
    </div>
  </div>
</section>
