---
import { WHATSAPP_LINK } from '../config';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-inner">
      <span class="eyebrow">Desenvolvimento web de alta performance</span>
      <h1>
        Sites que carregam em instantes e <span class="gradient-text">vendem 24 horas por dia</span>.
      </h1>
      <p class="hero-sub">
        Unimos design sob medida e a tecnologia web mais avançada do mercado
        para entregar carregamento instantâneo, topo do Google e segurança
        blindada — tudo para transformar seus visitantes em clientes.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={WHATSAPP_LINK} target="_blank" rel="noopener">
          Solicitar proposta gratuita
        </a>
        <a class="btn btn-outline" href="#comparativo">Ver comparativo</a>
      </div>
      <p class="hero-note">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
        Resposta em até 1 dia útil · Sem compromisso · Sem mensalidade
      </p>
      <ul class="hero-proof">
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
          Nota máxima no Google PageSpeed
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
          Carregamento em menos de 1 segundo
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
          Sem plugins vulneráveis
        </li>
      </ul>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="report-card">
        <div class="report-header">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="report-url">pagespeed.web.dev · seusite.com.br</span>
        </div>
        <div class="report-scores">
          <div>
            <div class="score-ring"><strong>100</strong></div>
            <span>Desempenho</span>
          </div>
          <div>
            <div class="score-ring"><strong>100</strong></div>
            <span>Acessibilidade</span>
          </div>
          <div>
            <div class="score-ring"><strong>100</strong></div>
            <span>Práticas recomendadas</span>
          </div>
          <div>
            <div class="score-ring"><strong>100</strong></div>
            <span>SEO</span>
          </div>
        </div>
        <div class="report-metrics">
          <div class="metric-row">
            <span>Primeiro conteúdo exibido</span>
            <strong>0,3 s</strong>
          </div>
          <div class="metric-row">
            <span>Velocidade de exibição</span>
            <strong>0,4 s</strong>
          </div>
          <div class="metric-row">
            <span>Tempo até interatividade total</span>
            <strong>0,5 s</strong>
          </div>
        </div>
      </div>
      <div class="float-chip chip-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
        0,4 s de carregamento
      </div>
      <div class="float-chip chip-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><polyline points="9 12 11 14 15 10" /></svg>
        Sem plugins vulneráveis
      </div>
    </div>
  </div>
</section>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rings = document.querySelectorAll<HTMLElement>('.score-ring');

  if (rings.length && !reduceMotion) {
    const DURATION = 1300;

    const animateRing = (ring: HTMLElement, delay: number) => {
      const num = ring.querySelector('strong');
      window.setTimeout(() => {
        const start = performance.now();
        const tick = (now: number) => {
          const progress = Math.min((now - start) / DURATION, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = Math.round(eased * 100);
          ring.style.background = `conic-gradient(var(--green) ${value}%, rgba(255, 255, 255, 0.08) ${value}%)`;
          if (num) num.textContent = String(value);
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }, delay);
    };

    rings.forEach((ring, i) => {
      ring.style.background =
        'conic-gradient(var(--green) 0%, rgba(255, 255, 255, 0.08) 0%)';
      const num = ring.querySelector('strong');
      if (num) num.textContent = '0';
      animateRing(ring, 300 + i * 180);
    });
  }
</script>
