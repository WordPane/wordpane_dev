---
interface Props {
  items?: string[];
}

const {
  items = [
    'Sites em até 3 dias úteis',
    'Sistemas sob medida',
    'Nota 90+ no PageSpeed',
    'Acompanhamento pelo CRM',
    'Atendimento em minutos',
    'Segurança de ponta a ponta',
    'Código 100% seu',
    'Suporte dedicado',
  ],
} = Astro.props;
---

<section class="trust" aria-label="Compromissos WordPane">
  <div class="marquee">
    {[false, true].map((hidden) => (
      <ul class="marquee-track" aria-hidden={hidden ? 'true' : undefined}>
        {items.map((item) => (
          <li>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4z" /></svg>
            {item}
          </li>
        ))}
      </ul>
    ))}
  </div>
</section>
