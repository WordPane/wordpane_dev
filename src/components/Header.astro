---
import { Image } from 'astro:assets';
import logoWhite from '../assets/brand/logo-white.png';
import { CRM_LINK } from '../config';
---

<header class="site-header">
  <div class="container">
    <a class="brand" href="/" aria-label="WordPane — voltar ao início">
      <Image src={logoWhite} alt="WordPane" width={500} format="webp" loading="eager" />
    </a>
    <nav class="main-nav" aria-label="Navegação principal">
      <a href="/desenvolvimento-de-sites/">Sites</a>
      <a href="/desenvolvimento-de-sistemas/">Sistemas</a>
      <a href="/#processo">Processo</a>
      <a href="/#faq">Dúvidas</a>
    </nav>
    <div class="header-actions">
      <a class="btn btn-outline btn-sm btn-crm" href={CRM_LINK} target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
        <span>Acesso ao CRM</span>
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
