---
import type { Faq as FaqItem } from '../data/faqs';

interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;
---

<section id="faq">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">Dúvidas frequentes</span>
      <h2>Perguntas e <span class="gradient-text">respostas</span></h2>
    </div>
    <div class="faq-list">
      {faqs.map((faq) => (
        <details data-reveal>
          <summary>{faq.q}</summary>
          <p>{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
