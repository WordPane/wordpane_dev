---
import { WHATSAPP_LINK } from '../config';

const items = [
  'Arquitetura blindada contra invasões',
  'Otimização para o Google (SEO técnico)',
  'Integração com WhatsApp e redes sociais',
  'Google Analytics e Search Console configurados',
  'Versão otimizada para celular',
  'Página de política de privacidade (LGPD)',
  'Treinamento para usar o site',
  'Suporte dedicado por 30 dias',
];
---

<section class="included">
  <div class="container included-grid">
    <div data-reveal>
      <span class="eyebrow">Tudo incluso</span>
      <h2>O que acompanha <span class="gradient-text">todo projeto</span></h2>
      <ul class="check-list">
        {items.map((item) => (
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
    <div class="guarantee-card" data-reveal>
      <h3>Proposta gratuita e sem compromisso</h3>
      <p>
        Conte o que você precisa e receba uma proposta com escopo, prazo e
        valor. Grátis e sem compromisso.
      </p>
      <a class="btn" href={WHATSAPP_LINK} target="_blank" rel="noopener">
        Quero minha proposta
      </a>
    </div>
  </div>
</section>
