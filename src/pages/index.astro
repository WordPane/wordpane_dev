---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import TechSection from '../components/TechSection.astro';
import StepsSection from '../components/StepsSection.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { faqs } from '../data/faqs';
import { agencyFeatures } from '../data/agency';

const trustItems = [
  'Sites em até 3 dias úteis',
  'Sistemas web sob medida',
  'Pequenas, médias e grandes empresas',
  'Nota 90+ no PageSpeed',
  'Acompanhamento pelo CRM',
  'Atendimento em minutos',
  'Código 100% seu',
  'Suporte dedicado',
];

const audience = [
  {
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" />',
    title: 'Pequenas empresas',
    desc: 'Sites profissionais e sistemas enxutos para profissionalizar a presença digital e organizar a rotina — com investimento acessível e entrega rápida.',
  },
  {
    icon: '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" />',
    title: 'Médias empresas',
    desc: 'Sistemas web que automatizam processos, integram suas ferramentas e dão visibilidade à operação para crescer sem travar a equipe.',
  },
  {
    icon: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /><path d="M10 6h4" /><path d="M10 10h4" /><path d="M10 14h4" /><path d="M10 18h4" />',
    title: 'Grandes empresas',
    desc: 'Projetos robustos com arquitetura escalável, permissões, integrações complexas e segurança — e o código-fonte sempre na sua mão.',
  },
];

const techs = [
  { name: 'TypeScript', desc: 'Código tipado de ponta a ponta: menos erros, manutenção mais barata.' },
  { name: 'WordPane Dev', desc: 'Sites estáticos ultrarrápidos, com nota máxima nas ferramentas do Google.' },
  { name: 'React', desc: 'Interfaces ricas e interativas para sistemas e painéis.' },
  { name: 'Node.js', desc: 'APIs rápidas e escaláveis para alimentar qualquer operação.' },
  { name: 'PostgreSQL', desc: 'Banco de dados robusto, íntegro e confiável para seus dados.' },
  { name: 'Cloudflare', desc: 'CDN global, proteção contra ataques e velocidade na borda.' },
  { name: 'Docker', desc: 'Ambientes idênticos do desenvolvimento à produção, sem surpresa.' },
  { name: 'Git & GitHub', desc: 'Versionamento completo: cada mudança registrada e reversível.' },
];

const steps = [
  {
    num: '01',
    title: 'Briefing e estratégia',
    desc: 'Uma conversa rápida para entender seu negócio, seu público e seus objetivos. Saímos dela com o caminho ideal para o seu projeto.',
    chip: 'Reunião rápida online',
  },
  {
    num: '02',
    title: 'Proposta e design',
    desc: 'Escopo, prazo e valor fechados por escrito. Você aprova o visual e as telas antes de qualquer linha de código.',
    chip: 'Você aprova antes de seguir',
  },
  {
    num: '03',
    title: 'Desenvolvimento',
    desc: 'Construímos com a tecnologia mais moderna do mercado e você acompanha cada etapa em tempo real pelo nosso CRM.',
    chip: 'Acompanhamento pelo CRM',
  },
  {
    num: '04',
    title: 'Entrega e evolução',
    desc: 'Projeto no ar com tudo configurado, treinamento incluso e suporte dedicado para os primeiros ajustes.',
    chip: 'Suporte dedicado incluso',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Base
  title="WordPane — Agência de Desenvolvimento de Sites e Sistemas Web"
  description="A WordPane é uma agência de desenvolvimento de sites e sistemas web sob medida para pequenas, médias e grandes empresas. Tecnologia moderna, entrega ágil e acompanhamento pelo CRM. Peça uma proposta gratuita."
  jsonLdExtra={[faqLd]}
>
  <Header />
  <main>
    <Hero />
    <TrustBar items={trustItems} />
    <FeatureGrid
      id="agencia"
      eyebrow="A agência"
      titleA="Mais que uma fornecedora,"
      titleB="uma parceira de tecnologia"
      intro="A WordPane é uma agência de desenvolvimento web feita de gente que constrói: time enxuto, processo transparente e obsessão por resultado — do primeiro site ao sistema que sustenta toda a sua operação."
      features={agencyFeatures}
      cols={3}
    />
    <Services />
    <FeatureGrid
      id="para-quem"
      eyebrow="Para quem fazemos"
      titleA="Soluções para empresas"
      titleB="de todos os tamanhos"
      intro="Do site que apresenta a empresa que está começando ao sistema web que sustenta grandes operações: o mesmo padrão de qualidade, na medida de cada momento."
      features={audience}
    />
    <TechSection
      id="tecnologias"
      eyebrow="Tecnologias"
      titleA="A mesma tecnologia das"
      titleB="maiores empresas do mundo"
      intro="Escolhemos ferramentas modernas e consolidadas para entregar projetos rápidos, seguros e baratos de manter — do site institucional ao sistema de missão crítica."
      techs={techs}
    />
    <StepsSection
      id="processo"
      eyebrow="Como funciona"
      titleA="Do primeiro contato à entrega,"
      titleB="sem mistério"
      intro="Você acompanha cada etapa pelo nosso CRM e aprova antes de seguirmos para a próxima. Sem surpresa no caminho."
      steps={steps}
    />
    <Faq faqs={faqs} />
    <CtaBand
      title="Pronto para tirar seu projeto do papel?"
      text="Do site ao sistema web: conte sua ideia no WhatsApp e receba uma proposta gratuita com escopo, prazo e valor — sem compromisso."
    />
  </main>
  <Footer />
  <WhatsAppFloat />
</Base>
