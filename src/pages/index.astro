---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Pain from '../components/Pain.astro';
import Benefits from '../components/Benefits.astro';
import Tech from '../components/Tech.astro';
import Comparison from '../components/Comparison.astro';
import Process from '../components/Process.astro';
import Included from '../components/Included.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<Base
  title="WordPane — Criação de Sites Profissionais de Alta Performance"
  description="Desenvolvemos sites ultrarrápidos, seguros e otimizados para o Google, feitos para converter visitantes em clientes. Veja o comparativo com WordPress e solicite uma proposta gratuita."
>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <Pain />
    <Benefits />
    <Tech />
    <Comparison />
    <Process />
    <Included />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
  <WhatsAppFloat />
</Base>
