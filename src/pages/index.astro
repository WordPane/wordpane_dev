---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import TechSection from '../components/TechSection.astro';
import StepsSection from '../components/StepsSection.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { faqs } from '../data/faqs';

const features = [
  {
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />',
    title: 'Agilidade de verdade',
    desc: 'Sites entregues em até 3 dias úteis e sistemas com entregas parciais frequentes. Seu projeto não fica meses no forno.',
  },
  {
    icon: '<circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />',
    title: 'Velocidade extrema',
    desc: 'Páginas que abrem em menos de 1 segundo e sistemas que respondem na hora. Velocidade vira conversão e produtividade.',
  },
  {
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><polyline points="9 12 11 14 15 10" />',
    title: 'Segurança de ponta a ponta',
    desc: 'Sem plugins vulneráveis, com criptografia, controle de acesso e backup automático. Seus dados e sua reputação protegidos.',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" />',
    title: 'Transparência total',
    desc: 'Você acompanha propostas, etapas e entregas pelo nosso CRM. Nada de projeto em caixa-preta.',
  },
  {
    icon: '<circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" />',
    title: 'Foco em conversão',
    desc: 'Cada página e cada tela são desenhadas para guiar o visitante até a ação: contato, orçamento ou compra.',
  },
  {
    icon: '<polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />',
    title: 'Código 100% seu',
    desc: 'Você recebe o código-fonte completo e documentado. Sem aprisionamento, sem dependência da gente para evoluir.',
  },
  {
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>',
    title: 'Atendimento próximo',
    desc: 'Fala direto com quem constrói, sem robô e sem fila. Resposta em poucos minutos, do briefing ao pós-lançamento.',
  },
  {
    icon: '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" />',
    title: 'Pronto para crescer',
    desc: 'Arquitetura que aguenta picos de tráfego e novas funcionalidades sem precisar recomeçar do zero.',
  },
];

const techs = [
  { name: 'TypeScript', desc: 'Código tipado de ponta a ponta: menos erros, manutenção mais barata.' },
  { name: 'Astro', desc: 'Sites estáticos ultrarrápidos, com nota máxima nas ferramentas do Google.' },
  { name: 'React', desc: 'Interfaces ricas e interativas para sistemas e painéis.' },
  { name: 'Node.js', desc: 'APIs rápidas e escaláveis para alimentar qualquer operação.' },
  { name: 'PostgreSQL', desc: 'Banco de dados robusto, íntegro e confiável para seus dados.' },
  { name: 'Cloudflare', desc: 'CDN global, proteção contra ataques e velocidade na borda.' },
  { name: 'Docker', desc: 'Ambientes idênticos do desenvolvimento à produção, sem surpresa.' },
  { name: 'Git & GitHub', desc: 'Versionamento completo: cada mudança registrada e reversível.' },
];

const steps = [
  {
    num: '01',
    title: 'Briefing e estratégia',
    desc: 'Uma conversa rápida para entender seu negócio, seu público e seus objetivos. Saímos dela com o caminho ideal para o seu projeto.',
    chip: 'Reunião rápida online',
  },
  {
    num: '02',
    title: 'Proposta e design',
    desc: 'Escopo, prazo e valor fechados por escrito. Você aprova o visual e as telas antes de qualquer linha de código.',
    chip: 'Você aprova antes de seguir',
  },
  {
    num: '03',
    title: 'Desenvolvimento',
    desc: 'Construímos com a tecnologia mais moderna do mercado e você acompanha cada etapa em tempo real pelo nosso CRM.',
    chip: 'Acompanhamento pelo CRM',
  },
  {
    num: '04',
    title: 'Entrega e evolução',
    desc: 'Projeto no ar com tudo configurado, treinamento incluso e suporte dedicado para os primeiros ajustes.',
    chip: 'Suporte dedicado incluso',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Base
  title="WordPane — Desenvolvimento de Sites e Sistemas sob Medida"
  description="A WordPane desenvolve sites ultrarrápidos e sistemas web sob medida. Tecnologia moderna, entrega ágil, segurança e acompanhamento pelo CRM. Peça uma proposta gratuita."
  jsonLdExtra={[faqLd]}
>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <Services />
    <FeatureGrid
      id="vantagens"
      eyebrow="Por que a WordPane"
      titleA="O que você ganha ao"
      titleB="trabalhar com a gente"
      intro="Não entregamos só código: entregamos velocidade, segurança e transparência do primeiro contato ao pós-lançamento."
      features={features}
    />
    <TechSection
      id="tecnologias"
      eyebrow="Tecnologias"
      titleA="A mesma tecnologia das"
      titleB="maiores empresas do mundo"
      intro="Escolhemos ferramentas modernas e consolidadas para entregar projetos rápidos, seguros e baratos de manter."
      techs={techs}
    />
    <StepsSection
      id="processo"
      eyebrow="Como funciona"
      titleA="Do primeiro contato à entrega,"
      titleB="sem mistério"
      intro="Você acompanha cada etapa pelo nosso CRM e aprova antes de seguirmos para a próxima. Sem surpresa no caminho."
      steps={steps}
    />
    <Faq faqs={faqs} />
    <CtaBand
      title="Pronto para tirar seu projeto do papel?"
      text="Conte sua ideia no WhatsApp e receba uma proposta gratuita com escopo, prazo e valor — sem compromisso."
    />
  </main>
  <Footer />
  <WhatsAppFloat />
</Base>
