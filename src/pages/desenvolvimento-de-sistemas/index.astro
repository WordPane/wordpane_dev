---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import TechSection from '../../components/TechSection.astro';
import Deliverables from '../../components/Deliverables.astro';
import StepsSection from '../../components/StepsSection.astro';
import CtaBand from '../../components/CtaBand.astro';
import Faq from '../../components/Faq.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';

const trustItems = [
  'Código 100% seu',
  'Backup automático diário',
  'Entregas parciais frequentes',
  'Acompanhamento pelo CRM',
  'Dados criptografados',
  'Integrações via API',
  'Suporte pós-entrega',
  'Escopo fechado, sem surpresa',
];

const features = [
  {
    icon: '<rect x="4" y="4" width="16" height="16" rx="2" /><rect x="9" y="9" width="6" height="6" /><line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" /><line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" /><line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="14" x2="23" y2="14" /><line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="14" x2="4" y2="14" />',
    title: 'Automação de processos',
    desc: 'Rotinas manuais e repetitivas viram fluxo automático: menos erro humano, mais tempo para o que gera resultado.',
  },
  {
    icon: '<line x1="12" y1="20" x2="12" y2="10" /><line x1="18" y1="20" x2="18" y2="4" /><line x1="6" y1="20" x2="6" y2="16" />',
    title: 'Painéis em tempo real',
    desc: 'Vendas, estoque, financeiro e operação em dashboards atualizados na hora. Decisão com dado, não com achismo.',
  },
  {
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><polyline points="9 12 11 14 15 10" />',
    title: 'Segurança e permissões',
    desc: 'Autenticação, perfis de acesso e criptografia de ponta a ponta. Cada pessoa vê só o que deve ver.',
  },
  {
    icon: '<polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />',
    title: 'Integrações via API',
    desc: 'Conectamos seu sistema a ERPs, meios de pagamento, WhatsApp, e-commerce e qualquer ferramenta com API.',
  },
  {
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2" /><polyline points="2 17 12 22 22 17" /><polyline points="2 12 12 17 22 12" />',
    title: 'Escala com sua empresa',
    desc: 'Arquitetura preparada para crescer em usuários, dados e funcionalidades sem precisar recomeçar do zero.',
  },
  {
    icon: '<path d="M21 12a9 9 0 1 1-9-9" /><polyline points="21 3 21 9 15 9" />',
    title: 'Backup automático',
    desc: 'Cópias diárias dos seus dados, com restauração rápida. Dormir tranquilo também é recurso.',
  },
  {
    icon: '<circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />',
    title: 'Acesso de qualquer lugar',
    desc: 'Sistema web: funciona no navegador, no computador ou no celular, sem instalar nada.',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" />',
    title: 'Transparência via CRM',
    desc: 'Você acompanha escopo, etapas e entregas do desenvolvimento pelo CRM da WordPane, em tempo real.',
  },
];

const techs = [
  { name: 'TypeScript', desc: 'Front-end e back-end na mesma linguagem tipada: menos erro, evolução mais rápida.' },
  { name: 'React', desc: 'Interfaces rápidas, componentizadas e agradáveis de usar no dia a dia.' },
  { name: 'Node.js', desc: 'APIs performáticas que aguentam o ritmo da sua operação.' },
  { name: 'PostgreSQL', desc: 'Banco de dados relacional robusto, íntegro e confiável.' },
  { name: 'APIs REST & Webhooks', desc: 'Integração com ERPs, pagamentos, WhatsApp e o que mais sua operação precisar.' },
  { name: 'Docker & Cloud', desc: 'Deploy reproduzível e infraestrutura que escala junto com o sistema.' },
  { name: 'Autenticação segura', desc: 'Login, sessões e permissões por perfil, com criptografia de ponta a ponta.' },
  { name: 'Testes automatizados', desc: 'Qualidade contínua: cada nova versão passa por testes antes de chegar a você.' },
];

const deliverables = [
  'Código-fonte 100% seu e documentado',
  'Autenticação e controle de permissões',
  'Backup automático diário',
  'Hospedagem configurada e monitorada',
  'Painéis e relatórios em tempo real',
  'Integrações com suas ferramentas',
  'Acompanhamento do projeto pelo CRM',
  'Treinamento da equipe',
  'Suporte pós-entrega',
];

const steps = [
  {
    num: '01',
    title: 'Descoberta',
    desc: 'Mapeamos seus processos, dores e requisitos em uma conversa objetiva com quem vive a operação no dia a dia.',
    chip: 'Workshop rápido online',
  },
  {
    num: '02',
    title: 'Escopo e protótipo',
    desc: 'Fechamos escopo, prazo e valor por escrito e você valida as telas em um protótipo navegável antes do código.',
    chip: 'Você valida antes de seguir',
  },
  {
    num: '03',
    title: 'Desenvolvimento em ciclos',
    desc: 'Entregas parciais frequentes, acompanhadas em tempo real pelo nosso CRM. Você testa cedo e opina sempre.',
    chip: 'Acompanhamento pelo CRM',
  },
  {
    num: '04',
    title: 'Homologação e lançamento',
    desc: 'Testes finais com sua equipe, treinamento completo e go-live assistido. Depois, suporte dedicado.',
    chip: 'Suporte pós-entrega',
  },
];

const faqs = [
  {
    q: 'Quanto custa um sistema sob medida?',
    a: 'Depende do escopo: módulos, integrações e número de usuários. Depois da conversa de descoberta, você recebe uma proposta gratuita com escopo, prazo e valor fechados — sem surpresa no meio do caminho.',
  },
  {
    q: 'Quanto tempo leva o desenvolvimento?',
    a: 'Varia com o tamanho do projeto, mas trabalhamos com entregas parciais frequentes: você começa a usar as primeiras funcionalidades em semanas, não meses, e o sistema evolui em ciclos.',
  },
  {
    q: 'O código do sistema é meu?',
    a: 'Sim, 100% seu. Você recebe o código-fonte completo e documentado. Nada de aprisionamento: qualquer equipe pode dar continuidade ao projeto.',
  },
  {
    q: 'Como acompanho o andamento do desenvolvimento?',
    a: 'Pelo nosso CRM, em crm.wordpane.dev. Escopo, etapas, entregas e arquivos ficam disponíveis em tempo real, do início ao fim do projeto.',
  },
  {
    q: 'Meus dados ficam seguros?',
    a: 'Sim. Criptografia de ponta a ponta, controle de acesso por perfil, backup automático diário e adequação à LGPD. Segurança é requisito, não opcional.',
  },
  {
    q: 'E se eu precisar de novas funcionalidades depois?',
    a: 'Sem problema. O sistema é construído para evoluir: novos módulos e integrações entram em novos ciclos de desenvolvimento, com proposta própria.',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Base
  title="Desenvolvimento de Sistemas Web sob Medida | WordPane"
  description="Desenvolvemos sistemas web sob medida: ERPs, CRMs, painéis e automações com segurança, integrações e dados em tempo real. Código 100% seu. Peça uma proposta gratuita."
  jsonLdExtra={[faqLd]}
>
  <Header />
  <main>
    <PageHero
      eyebrow="Desenvolvimento de sistemas"
      titleA="Sistemas web sob medida que"
      titleB="automatizam sua operação."
      sub="Chega de planilha solta e processo manual. Centralizamos seus dados, automatizamos rotinas e entregamos painéis em tempo real — com agilidade e segurança."
      note="Escopo fechado antes de começar · Código 100% seu · Proposta gratuita"
      ctaMessage="Olá! Quero uma proposta gratuita para desenvolvimento de sistema."
      secondaryLabel="Ver tecnologias"
      secondaryHref="#tecnologias"
    >
      <div class="hero-visual" aria-hidden="true">
        <div class="report-card">
          <div class="report-header">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="report-url">app.suaempresa.com.br · painel</span>
          </div>
          <div class="dash-stats">
            <div class="dash-stat">
              <strong>R$ 12.480</strong>
              <span>Vendas hoje</span>
            </div>
            <div class="dash-stat">
              <strong>86</strong>
              <span>Pedidos</span>
            </div>
            <div class="dash-stat">
              <strong>34</strong>
              <span>Usuários online</span>
            </div>
          </div>
          <div class="dash-row">
            <div class="cwv-label">
              <span>Meta do mês</span>
              <strong>82%</strong>
            </div>
            <div class="cwv-bar"><i style="width: 82%"></i></div>
          </div>
          <div class="dash-row">
            <div class="cwv-label">
              <span>Estoque</span>
              <strong>64%</strong>
            </div>
            <div class="cwv-bar"><i style="width: 64%"></i></div>
          </div>
          <div class="dash-row">
            <div class="cwv-label">
              <span>Tickets resolvidos</span>
              <strong>91%</strong>
            </div>
            <div class="cwv-bar"><i style="width: 91%"></i></div>
          </div>
        </div>
        <div class="float-chip chip-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
          Dados em tempo real
        </div>
        <div class="float-chip chip-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><polyline points="9 12 11 14 15 10" /></svg>
          Backup automático diário
        </div>
      </div>
    </PageHero>
    <TrustBar items={trustItems} />
    <FeatureGrid
      id="recursos"
      eyebrow="Recursos e benefícios"
      titleA="O que seu sistema"
      titleB="entrega no dia a dia"
      intro="Cada sistema é desenhado para a sua operação — mas estes recursos são padrão em tudo o que construímos."
      features={features}
    />
    <TechSection
      id="tecnologias"
      eyebrow="Tecnologias"
      titleA="Stack moderna,"
      titleB="resultado sólido"
      intro="Tecnologia consolidada e amplamente adotada: seu sistema não fica refém de moda passageira nem de fornecedor único."
      techs={techs}
    />
    <Deliverables
      eyebrow="Tudo incluso"
      titleA="O que acompanha"
      titleB="todo sistema"
      intro="Sem item cobrado por fora: o que está aqui entra em todo sistema que entregamos, do primeiro ao último."
      items={deliverables}
      ctaTitle="Proposta gratuita e sem compromisso"
      ctaText="Conte o processo que trava sua operação e receba uma proposta com escopo, prazo e valor fechados."
      ctaMessage="Olá! Quero uma proposta gratuita para desenvolvimento de sistema."
    />
    <StepsSection
      id="processo"
      eyebrow="Como funciona"
      titleA="Do processo manual ao sistema no ar,"
      titleB="sem mistério"
      intro="Você valida o protótipo antes do código e acompanha cada ciclo pelo nosso CRM. Sem surpresa no caminho."
      steps={steps}
    />
    <Faq faqs={faqs} />
    <CtaBand
      title="Pronto para automatizar sua operação?"
      text="Conte no WhatsApp o processo que mais consome tempo da sua equipe e receba uma proposta gratuita com escopo, prazo e valor."
      ctaMessage="Olá! Quero uma proposta gratuita para desenvolvimento de sistema."
    />
  </main>
  <Footer />
  <WhatsAppFloat />
</Base>
